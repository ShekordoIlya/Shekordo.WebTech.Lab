@model Microsoft.AspNetCore.Mvc.Rendering.SelectList
@{
    ViewData["Title"] = "Index";
}

<main class="container">
    <div class="row mt-4">
        <div class="col-md-8">
            <h3>@ViewData["text"]</h3>
            <p>Кафедра МПСС</p>
            <p>Гламаздин И.И.</p>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <h4>Список групп</h4>
            <ol type="A">
    @for (int i = 0; i < 5; i++)
    {
        <li>элемент @i списка</li>
    }
</ol>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-8">
            <h4>Форма для отправки данных</h4>
            <form method="post" asp-action="Index" class="row g-3">
                <div class="col-md-12">
                    <label for="userName" class="form-label">Ваше имя:</label>
                    <input type="text" class="form-control" id="userName" name="userName" placeholder="Введите ваше имя" />
                </div>

                <div class="col-md-12">
                    <label class="form-label">Выберите пол:</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="gender" id="male" value="male" />
                        <label class="form-check-label" for="male">Мужской</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="gender" id="female" value="female" />
                        <label class="form-check-label" for="female">Женский</label>
                    </div>
                </div>

                <div class="col-md-12">
                    <label class="form-label">Выберите интересы:</label>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="interests" id="programming" value="programming" />
                        <label class="form-check-label" for="programming">Программирование</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="interests" id="design" value="design" />
                        <label class="form-check-label" for="design">Дизайн</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="interests" id="testing" value="testing" />
                        <label class="form-check-label" for="testing">Тестирование</label>
                    </div>
                </div>

                <div class="col-md-12">
                    <label for="selDemo" class="form-label">Выберите элемент:</label>
                    <select class="form-select" id="selDemo" name="selDemo" asp-items="Model"></select>
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Отправить</button>
                </div>
            </form>
        </div>
    </div>
</main>