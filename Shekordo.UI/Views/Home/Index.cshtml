@model SelectList
@{
    ViewBag.Title = "Index";
}

<h1>@ViewData["text"]</h1>

<h2>Список (через цикл for)</h2>
<ol type="A">
    @for (int i = 0; i < 5; i++)
    {
        <li>элемент @i списка</li>
    }
</ol>

<hr />

<h2>Форма</h2>
<form method="post" action="#">
    <div class="row mb-3">
        <label class="col-sm-2 col-form-label">Выберите элемент:</label>
        <div class="col-sm-10">
            <select class="form-select" asp-items="Model" name="selDemo"></select>
        </div>
    </div>

    <div class="row">
        <div class="col-sm-10 offset-sm-2">
            <button type="submit" class="btn btn-primary">Отправить</button>
        </div>
    </div>
</form>