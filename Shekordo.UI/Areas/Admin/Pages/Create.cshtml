@page
@model Shekordo.UI.Areas.Admin.Pages.CreateModel
@{
    ViewData["Title"] = "Create";
}

<h1>Создать блюдо</h1>

<h4>Новое блюдо</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group mb-3">
                <label asp-for="Dish.Name" class="control-label">Название</label>
                <input asp-for="Dish.Name" class="form-control" />
                <span asp-validation-for="Dish.Name" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Dish.Description" class="control-label">Описание</label>
                <input asp-for="Dish.Description" class="form-control" />
                <span asp-validation-for="Dish.Description" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Dish.Calories" class="control-label">Калории</label>
                <input asp-for="Dish.Calories" class="form-control" />
                <span asp-validation-for="Dish.Calories" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Dish.CategoryId" class="control-label">Категория</label>
                <select asp-for="Dish.CategoryId" class="form-control" asp-items="ViewBag.CategoryId"></select>
            </div>
            
            <div class="mb-3">
                <label asp-for="Image" class="form-label">Изображение</label>
                <input asp-for="Image" class="form-control" type="file" />
            </div>
            
            <div class="form-group">
                <input type="submit" value="Создать" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Вернуться к списку</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}