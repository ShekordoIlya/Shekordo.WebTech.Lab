@page
@model Shekordo.UI.Areas.Admin.Pages.IndexModel
@{
    ViewData["Title"] = "Администрирование";
}

<h1>Блюда</h1>
<p>
    <a asp-page="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Create New
    </a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Название</th>
            <th>Описание</th>
            <th>Калории</th>
            <th>Изображение</th>
            <th>Категория</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Dish)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Calories</td>
                <td><img src="@item.Image" width="80" alt="@item.Name" /></td>
                <td>@item.Category?.Name</td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-success">
                        <i class="fa-solid fa-pen-to-square"></i> Edit
                    </a>
                    <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-info ms-1 me-1">
                        <i class="fa-solid fa-info"></i> Details
                    </a>
                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-danger">
                        <i class="fa-regular fa-trash-can"></i> Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<pager admin="true"
       current-page="@Model.CurrentPage"
       total-pages="@Model.TotalPages"></pager>
