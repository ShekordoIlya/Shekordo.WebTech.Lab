@page "{id:int}"
@model Shekordo.UI.Areas.Admin.Pages.DeleteModel
@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>
<h3>Вы уверены, что хотите удалить это блюдо?</h3>
<div>
    <h4>Dish</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Dish.Name</dd>
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Dish.Description</dd>
        <dt class="col-sm-2">Calories</dt>
        <dd class="col-sm-10">@Model.Dish.Calories</dd>
    </dl>
    <form method="post">
        <input type="hidden" asp-for="Dish.Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-page="./Index">Back to List</a>
    </form>
</div>
