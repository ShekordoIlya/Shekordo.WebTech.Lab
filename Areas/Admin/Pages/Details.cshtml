@page "{id:int}"
@model Shekordo.UI.Areas.Admin.Pages.DetailsModel
@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>
<div>
    <h4>Dish</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Dish.Name</dd>
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Dish.Description</dd>
        <dt class="col-sm-2">Calories</dt>
        <dd class="col-sm-10">@Model.Dish.Calories</dd>
        <dt class="col-sm-2">Image</dt>
        <dd class="col-sm-10"><img src="@Model.Dish.Image" width="200" alt="@Model.Dish.Name" /></dd>
        <dt class="col-sm-2">Category</dt>
        <dd class="col-sm-10">@Model.Dish.Category?.Name</dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Dish.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
