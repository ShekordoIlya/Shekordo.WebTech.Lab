@page
@model Shekordo.UI.Areas.Admin.Pages.CreateModel
@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>
<h4>Dish</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Dish.Name" class="form-label"></label>
                <input asp-for="Dish.Name" class="form-control" />
                <span asp-validation-for="Dish.Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Dish.Description" class="form-label"></label>
                <input asp-for="Dish.Description" class="form-control" />
                <span asp-validation-for="Dish.Description" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Dish.Calories" class="form-label"></label>
                <input asp-for="Dish.Calories" class="form-control" />
                <span asp-validation-for="Dish.Calories" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Dish.CategoryId" class="form-label"></label>
                <select asp-for="Dish.CategoryId" class="form-select" asp-items="@(ViewData["CategoryId"] as SelectList)"></select>
            </div>
            <div class="mb-3">
                <label asp-for="Image" class="form-label">Изображение</label>
                <input asp-for="Image" class="form-control" type="file" />
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>
<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
