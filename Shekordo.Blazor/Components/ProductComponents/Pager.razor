@implements IDisposable
@rendermode InteractiveServer

<div class="btn-group mt-3" role="group" aria-label="Pager">
    <button type="button" class="btn btn-outline-primary @(PreviousEnabled ? "" : "disabled")"
            @onclick="() => OnPageSelected(ProductService.CurrentPage - 1)">
        <span aria-hidden="true">&laquo;</span>
    </button>
    @for (var pageIndex = 1; pageIndex <= ProductService.TotalPages; pageIndex++)
    {
        var pageNumber = pageIndex;
        <button type="button" class="btn btn-outline-primary @(IsActive(pageNumber) ? "active" : "")"
                @onclick="() => OnPageSelected(pageNumber)">
            @pageNumber
        </button>
    }
    <button type="button" class="btn btn-outline-primary @(NextEnabled ? "" : "disabled")"
            @onclick="() => OnPageSelected(ProductService.CurrentPage + 1)">
        <span aria-hidden="true">&raquo;</span>
    </button>
</div>

@code {
    [CascadingParameter]
    public IProductService<Dish> ProductService { get; set; } = default!;

    bool PreviousEnabled => ProductService.CurrentPage != 1;
    bool NextEnabled => ProductService.CurrentPage != ProductService.TotalPages;
    bool IsActive(int pageNo) => pageNo == ProductService.CurrentPage;

    protected override void OnInitialized()
    {
        ProductService.ListChanged += StateHasChanged;
    }

    private async Task OnPageSelected(int pageNo)
    {
        if (pageNo < 1 || pageNo > ProductService.TotalPages)
        {
            return;
        }

        await ProductService.GetProducts(pageNo);
    }

    public void Dispose()
    {
        ProductService.ListChanged -= StateHasChanged;
    }
}
